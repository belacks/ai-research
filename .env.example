# ==========================================
# CRN — Crawl Research Node Configuration
# ==========================================

# Telegram Push Notifications
# Get your bot token from @BotFather on Telegram
# Get your chat ID by messaging @userinfobot
TELEGRAM_BOT_TOKEN="YOUR_BOT_TOKEN_HERE"
TELEGRAM_CHAT_ID="YOUR_CHAT_ID_HERE"

# Local LLM / SLM Configuration (Ollama)
# OLLAMA_BASE_URL points to the host machine where Ollama runs
# TARGET_MODEL must match a model you've pulled with `ollama pull`
OLLAMA_BASE_URL="http://host.docker.internal:11434"
TARGET_MODEL="qwen3:2b"

# Stateful Scheduler Settings
# How often (in hours) the bot pings you for a scheduled crawl
SCHEDULE_INTERVAL_HOURS=6

# Customize this to your background — the LLM uses it to score relevance for you personally
# Optional: defaults to the generic profile below if omitted
RESEARCHER_PROFILE="A technology researcher interested in AI, Data Science, and global tech trends."